 /*
  ==========================================
      NEO-6M GPS + ESP32  (MEJORADO)
  ==========================================

  Funciones:
  - Latitud y Longitud
  - Altitud
  - Velocidad
  - Satélites
  - Fecha/Hora LOCAL Ecuador
  - HDOP (precisión GPS)
  - Detección de errores
  - Evita datos repetidos

  UART2 ESP32:
    RX2 -> GPIO16  (conectar al TX del GPS)
    TX2 -> GPIO17  (conectar al RX del GPS)

  GPS Baud   : 9600
  Serial Baud: 115200
*/

#include <HardwareSerial.h>
#include <TinyGPSPlus.h>

// ==========================================
// CONFIGURACIÓN
// ==========================================
#define GPS_RX     16
#define GPS_TX     17
#define GPS_BAUD   9600

// Ecuador Continental = UTC -5
#define UTC_OFFSET -5

TinyGPSPlus gps;
HardwareSerial GPSSerial(2);

// Control de tiempo
unsigned long lastPrint = 0;

// Mostrar error solo una vez
bool gpsErrorShown = false;

// ==========================================
// SETUP
// ==========================================
void setup() {

  Serial.begin(115200);
  delay(1000);

  // Inicializar UART2
  GPSSerial.begin(GPS_BAUD, SERIAL_8N1, GPS_RX, GPS_TX);

  Serial.println();
  Serial.println("====================================");
  Serial.println("     NEO-6M GPS + ESP32");
  Serial.println("====================================");
  Serial.println("Esperando señal GPS...");
  Serial.println("La primera conexion puede tardar");
  Serial.println("1 a 3 minutos al aire libre.");
  Serial.println("====================================");
}

// ==========================================
// LOOP
// ==========================================
void loop() {

  // Leer todos los datos del GPS
  while (GPSSerial.available() > 0) {
    gps.encode(GPSSerial.read());
  }

  // Mostrar datos cada 2 segundos
  if (millis() - lastPrint >= 2000) {
    lastPrint = millis();
    printGPSData();
  }

  // Error si no llegan datos
  if (millis() > 10000 &&
      gps.charsProcessed() < 10 &&
      !gpsErrorShown) {

    Serial.println();
    Serial.println("ERROR:");
    Serial.println("No llegan datos del GPS.");
    Serial.println("Revisa:");
    Serial.println("- Cableado TX/RX");
    Serial.println("- Alimentacion");
    Serial.println("- Baudrate");
    Serial.println();

    gpsErrorShown = true;
  }
}

// ==========================================
// MOSTRAR DATOS GPS
// ==========================================
void printGPSData() {

  Serial.println();
  Serial.println("=========== GPS ===========");

  // ======================================
  // UBICACIÓN
  // ======================================
  if (gps.location.isValid() &&
      gps.location.isUpdated()) {

    Serial.print("Latitud    : ");
    Serial.println(gps.location.lat(), 6);

    Serial.print("Longitud   : ");
    Serial.println(gps.location.lng(), 6);

  } else {

    Serial.println("Ubicacion  : Sin FIX GPS");
  }

  // ======================================
  // ALTITUD
  // ======================================
  if (gps.altitude.isValid()) {

    Serial.print("Altitud    : ");
    Serial.print(gps.altitude.meters(), 2);
    Serial.println(" m");
  }

  // ======================================
  // VELOCIDAD
  // ======================================
  if (gps.speed.isValid()) {

    Serial.print("Velocidad  : ");
    Serial.print(gps.speed.kmph(), 2);
    Serial.println(" km/h");
  }

  // ======================================
  // SATÉLITES
  // ======================================
  if (gps.satellites.isValid()) {

    Serial.print("Satelites  : ");
    Serial.println(gps.satellites.value());
  }

  // ======================================
  // HDOP (PRECISIÓN)
  // ======================================
  if (gps.hdop.isValid()) {

    Serial.print("HDOP       : ");
    Serial.println(gps.hdop.hdop(), 1);
  }

  // ======================================
  // FECHA Y HORA LOCAL ECUADOR
  // ======================================
  if (gps.date.isValid() &&
      gps.time.isValid()) {

    int horaLocal = gps.time.hour() + UTC_OFFSET;

    // Ajustar si queda negativa
    if (horaLocal < 0) {
      horaLocal += 24;
    }

    // Ajustar si supera 23
    if (horaLocal >= 24) {
      horaLocal -= 24;
    }

    Serial.printf(
      "Fecha/Hora: %02d/%02d/%04d  %02d:%02d:%02d\n",
      gps.date.day(),
      gps.date.month(),
      gps.date.year(),
      horaLocal,
      gps.time.minute(),
      gps.time.second()
    );
  }

  // ======================================
  // ESTADO GPS
  // ======================================
  if (gps.satellites.isValid()) {

    if (gps.satellites.value() >= 4) {
      Serial.println("Estado     : GPS CONECTADO");
    } else {
      Serial.println("Estado     : Buscando satelites...");
    }
  }

  Serial.println("===========================");
}
